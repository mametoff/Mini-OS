qemu-system-x86_64 \
    -cpu core2duo \
    -smp cores=2,threads=1,sockets=1 \
    -m 512M \
    -netdev user,id=net0 \
    -device rtl8139,netdev=net0 \
    -drive file=vm.img,format=raw,if=ide,media=disk,index=0 \
    -drive file=minios.iso,format=raw,if=ide,media=cdrom,index=1 \
    -boot order=dc \
    -nographic
